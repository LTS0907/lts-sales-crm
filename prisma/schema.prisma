generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Contact {
  id                  String               @id
  createdAt           DateTime             @default(now())
  updatedAt           DateTime
  name                String
  nameKana            String?
  company             String?
  title               String?
  email               String?
  phone               String?
  lineId              String?
  gmailAlias          String?
  website             String?
  address             String?
  photoPath           String?
  companySummary      String?
  companySummaryAt    DateTime?
  contactSummary      String?
  contactSummaryAt    DateTime?
  cardImageUrl        String?
  connectionType      String?
  department          String?
  emailBody           String?
  emailSentAt         DateTime?
  emailStatus         String               @default("UNSENT")
  emailSubject        String?
  episodeMemo         String?
  followUpDate        DateTime?
  followUpStatus      String               @default("NOT_SET")
  followUpText        String?
  nextAction          String?
  recommendedServices String?
  salesPhase          String               @default("LEAD")
  serviceReason       String?
  touchNumber         Int                  @default(0)
  driveFolderId       String?
  Exchange            Exchange[]
  FollowUpLog         FollowUpLog[]
  GroupMember         GroupMember[]
  MeetingParticipant  MeetingParticipant[]
  Note                Note[]
  ServicePhase        ServicePhase[]
  TaskLink            TaskLink[]
  Subscription        Subscription[]
  Contract            Contract[]
  AccountsReceivable  AccountsReceivable[]
  Revenue             Revenue[]
}

model Exchange {
  id          String   @id
  createdAt   DateTime @default(now())
  description String
  direction   String
  contactId   String
  Contact     Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
}

model FollowUpLog {
  id          String    @id
  createdAt   DateTime  @default(now())
  contactId   String
  touchNumber Int
  subject     String?
  body        String?
  status      String    @default("DRAFTED")
  sentAt      DateTime?
  Contact     Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)
}

model Group {
  id          String        @id
  createdAt   DateTime      @default(now())
  name        String
  description String?
  type        String        @default("CUSTOM")
  GroupMember GroupMember[]
}

model GroupMember {
  groupId      String
  contactId    String
  consentGiven Boolean @default(false)
  Contact      Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  Group        Group   @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@id([groupId, contactId])
}

model Meeting {
  id                 String               @id
  createdAt          DateTime             @default(now())
  title              String?
  date               DateTime
  location           String?
  notes              String?
  MeetingParticipant MeetingParticipant[]
}

model MeetingParticipant {
  meetingId String
  contactId String
  Contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  Meeting   Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@id([meetingId, contactId])
}

model Note {
  id        String   @id
  createdAt DateTime @default(now())
  updatedAt DateTime
  content   String
  category  String   @default("GENERAL")
  contactId String
  Contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
}

model ServicePhase {
  id        String   @id
  contactId String
  service   String
  phase     String
  updatedAt DateTime
  Contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([contactId, service])
}

model TaskLink {
  id           String   @id
  googleTaskId String   @unique
  taskListId   String
  contactId    String
  presetLabel  String?
  createdAt    DateTime @default(now())
  Contact      Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
}

model Subscription {
  id             String          @id @default(cuid())
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  contactId      String
  serviceName    String
  billingType    String          // "FIXED" or "VARIABLE"
  fixedAmount    Int?
  description    String
  invoiceSubject String
  status         String          @default("ACTIVE") // ACTIVE / PAUSED / CANCELLED
  startDate      DateTime
  endDate        DateTime?
  cancelledAt    DateTime?
  notes          String?
  Contact        Contact         @relation(fields: [contactId], references: [id], onDelete: Cascade)
  BillingRecord  BillingRecord[]
}

model BillingRecord {
  id                 String              @id @default(cuid())
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  subscriptionId     String
  billingMonth       String              // "2026-04" format
  amount             Int?
  amountConfirmed    Boolean             @default(false)
  status             String              @default("PENDING") // PENDING / GENERATED / SENT / DOWNLOADED
  spreadsheetId      String?
  spreadsheetUrl     String?
  generatedAt        DateTime?
  sentAt             DateTime?
  sentMethod         String?             // "EMAIL" / "PDF_DOWNLOAD"
  errorMessage       String?
  Subscription       Subscription        @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  AccountsReceivable AccountsReceivable?

  @@unique([subscriptionId, billingMonth])
}

// 売掛金（Accounts Receivable）
model AccountsReceivable {
  id              String              @id @default(cuid())
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  contactId       String
  billingRecordId String?             @unique // サブスク由来（任意）
  source          String              @default("MANUAL") // SUBSCRIPTION / MANUAL
  serviceName     String
  invoiceSubject  String?
  spreadsheetId   String?             // 請求書スプレッドシート
  spreadsheetUrl  String?
  subtotal        Int                 // 税抜
  taxAmount       Int                 // 消費税
  amount          Int                 // 税込合計（＝請求金額）
  paidAmount      Int                 @default(0)
  invoicedAt      DateTime            // 請求日（売上計上日）
  dueDate         DateTime            // 支払期日（デフォ：翌月末、編集可）
  paidAt          DateTime?
  status          String              @default("OPEN") // OPEN / PARTIAL / PAID / OVERDUE / WRITTEN_OFF
  notes           String?
  Contact         Contact             @relation(fields: [contactId], references: [id], onDelete: Cascade)
  BillingRecord   BillingRecord?      @relation(fields: [billingRecordId], references: [id], onDelete: SetNull)
  Revenue         Revenue?
  Allocations     PaymentAllocation[]

  @@index([contactId])
  @@index([status])
  @@index([dueDate])
}

// 売上計上（発生主義：請求日=売上計上日）
model Revenue {
  id                   String             @id @default(cuid())
  createdAt            DateTime           @default(now())
  accountsReceivableId String             @unique
  contactId            String
  serviceName          String
  subtotal             Int                // 税抜
  taxAmount            Int
  totalAmount          Int                // 税込
  recognizedAt         DateTime           // 売上計上日（＝請求日）
  fiscalMonth          String             // "2026-04" 形式
  AccountsReceivable   AccountsReceivable @relation(fields: [accountsReceivableId], references: [id], onDelete: Cascade)
  Contact              Contact            @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([fiscalMonth])
  @@index([contactId])
}

// 入金明細（MF/楽天等からの取込）
model PaymentTransaction {
  id                  String              @id @default(cuid())
  createdAt           DateTime            @default(now())
  source              String              // "MF" / "RAKUTEN" / "MANUAL"
  externalId          String?             @unique // 元データのID（重複取込防止）
  transactionDate     DateTime
  direction           String              @default("IN") // IN / OUT
  amount              Int                                  // 常に正の値。direction で方向を示す
  balance             Int?                                 // 取引後残高（CSVにあれば）
  description         String?                              // 摘要全文
  payerName           String              // 振込人名義（OUT時は振込先）
  payerNameNormalized String              // 正規化済み（マッチング用）
  payerType           String              @default("UNKNOWN") // COMPANY / PERSON / UNKNOWN
  rawData             Json?
  matchStatus         String              @default("UNMATCHED") // UNMATCHED / NEEDS_REVIEW / AUTO_MATCHED / MANUAL_MATCHED / OTHER_REVENUE / IGNORED
  reviewNote          String?
  Allocations         PaymentAllocation[]

  @@index([transactionDate])
  @@index([matchStatus])
  @@index([direction])
}

// 入金 ↔ 売掛 の割当（部分入金・按分対応）
model PaymentAllocation {
  id                   String             @id @default(cuid())
  createdAt            DateTime           @default(now())
  paymentTransactionId String
  accountsReceivableId String
  allocatedAmount      Int
  PaymentTransaction   PaymentTransaction @relation(fields: [paymentTransactionId], references: [id], onDelete: Cascade)
  AccountsReceivable   AccountsReceivable @relation(fields: [accountsReceivableId], references: [id], onDelete: Cascade)

  @@unique([paymentTransactionId, accountsReceivableId])
}

model Contract {
  id                String    @id @default(cuid())
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  contactId         String
  templateName      String
  status            String    @default("SENT") // SENT / VIEWED / SIGNED
  signingToken      String    @unique
  driveFileId       String?
  signedDriveFileId String?
  fieldValues       Json?
  sentAt            DateTime  @default(now())
  viewedAt          DateTime?
  signedAt          DateTime?
  signerIp          String?
  viewerIp          String?
  signerUserAgent   String?
  viewerUserAgent   String?
  signedPdfHash     String?
  certDriveFileId   String?
  Contact           Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)
}

model BackupLog {
  id          String   @id @default(cuid())
  executedAt  DateTime @default(now())
  kind        String   // BACKUP / DRILL / CLEANUP
  status      String   // SUCCESS / PARTIAL / FAILED
  sheetsOk    Boolean  @default(false)
  githubOk    Boolean  @default(false)
  driveDumpUrl String?
  tableCounts Json?
  errors      String[] @default([])
  durationMs  Int      @default(0)
  notes       String?
}
