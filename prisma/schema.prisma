generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Contact {
  id                  String               @id
  createdAt           DateTime             @default(now())
  updatedAt           DateTime
  name                String
  nameKana            String?
  company             String?
  title               String?
  email               String?
  phone               String?
  lineId              String?
  gmailAlias          String?
  website             String?
  address             String?
  photoPath           String?
  companySummary      String?
  companySummaryAt    DateTime?
  contactSummary      String?
  contactSummaryAt    DateTime?
  cardImageUrl        String?
  connectionType      String?
  department          String?
  emailBody           String?
  emailSentAt         DateTime?
  emailStatus         String               @default("UNSENT")
  emailSubject        String?
  episodeMemo         String?
  followUpDate        DateTime?
  followUpStatus      String               @default("NOT_SET")
  followUpText        String?
  nextAction          String?
  recommendedServices String?
  salesPhase          String               @default("LEAD")
  serviceReason       String?
  touchNumber         Int                  @default(0)
  driveFolderId       String?
  Exchange            Exchange[]
  FollowUpLog         FollowUpLog[]
  GroupMember         GroupMember[]
  MeetingParticipant  MeetingParticipant[]
  Note                Note[]
  ServicePhase        ServicePhase[]
  TaskLink            TaskLink[]
  Subscription        Subscription[]
  Contract            Contract[]
}

model Exchange {
  id          String   @id
  createdAt   DateTime @default(now())
  description String
  direction   String
  contactId   String
  Contact     Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
}

model FollowUpLog {
  id          String    @id
  createdAt   DateTime  @default(now())
  contactId   String
  touchNumber Int
  subject     String?
  body        String?
  status      String    @default("DRAFTED")
  sentAt      DateTime?
  Contact     Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)
}

model Group {
  id          String        @id
  createdAt   DateTime      @default(now())
  name        String
  description String?
  type        String        @default("CUSTOM")
  GroupMember GroupMember[]
}

model GroupMember {
  groupId      String
  contactId    String
  consentGiven Boolean @default(false)
  Contact      Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  Group        Group   @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@id([groupId, contactId])
}

model Meeting {
  id                 String               @id
  createdAt          DateTime             @default(now())
  title              String?
  date               DateTime
  location           String?
  notes              String?
  MeetingParticipant MeetingParticipant[]
}

model MeetingParticipant {
  meetingId String
  contactId String
  Contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  Meeting   Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@id([meetingId, contactId])
}

model Note {
  id        String   @id
  createdAt DateTime @default(now())
  updatedAt DateTime
  content   String
  category  String   @default("GENERAL")
  contactId String
  Contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
}

model ServicePhase {
  id        String   @id
  contactId String
  service   String
  phase     String
  updatedAt DateTime
  Contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([contactId, service])
}

model TaskLink {
  id           String   @id
  googleTaskId String   @unique
  taskListId   String
  contactId    String
  presetLabel  String?
  createdAt    DateTime @default(now())
  Contact      Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
}

model Subscription {
  id             String          @id @default(cuid())
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  contactId      String
  serviceName    String
  billingType    String          // "FIXED" or "VARIABLE"
  fixedAmount    Int?
  description    String
  invoiceSubject String
  status         String          @default("ACTIVE") // ACTIVE / PAUSED / CANCELLED
  startDate      DateTime
  endDate        DateTime?
  cancelledAt    DateTime?
  notes          String?
  Contact        Contact         @relation(fields: [contactId], references: [id], onDelete: Cascade)
  BillingRecord  BillingRecord[]
}

model BillingRecord {
  id              String        @id @default(cuid())
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  subscriptionId  String
  billingMonth    String        // "2026-04" format
  amount          Int?
  amountConfirmed Boolean       @default(false)
  status          String        @default("PENDING") // PENDING / GENERATED / SENT / DOWNLOADED
  spreadsheetId   String?
  spreadsheetUrl  String?
  generatedAt     DateTime?
  sentAt          DateTime?
  sentMethod      String?       // "EMAIL" / "PDF_DOWNLOAD"
  errorMessage    String?
  Subscription    Subscription  @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@unique([subscriptionId, billingMonth])
}

model Contract {
  id                String    @id @default(cuid())
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  contactId         String
  templateName      String
  status            String    @default("SENT") // SENT / VIEWED / SIGNED
  signingToken      String    @unique
  driveFileId       String?
  signedDriveFileId String?
  fieldValues       Json?
  sentAt            DateTime  @default(now())
  viewedAt          DateTime?
  signedAt          DateTime?
  signerIp          String?
  Contact           Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)
}
